<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Doctor Schedule 🏨</title>
    <link rel="stylesheet" href="/css/apptlist.css"> 
</head>
<body>
        <%- include('../partials/navbar') %>

    <div class="container">
        <h1>Your Appointments</h1>

        <% if (docAppt && docAppt.length > 0) { %>
    <table class="appointment-table">
        <thead>
            <tr>
                <th>Patient</th>
                <th>Date & Time</th>
                <th>Status</th>
            </tr>
        </thead>
        <tbody>
            <% docAppt.forEach(appt => { %>
                <tr>
                    <td>
                        <% if (appt.patient) { %>
                            <a href="/appt/<%= appt._id %>/notes" class="patient-link">
                                <%= appt.patient.username %>
                            </a>
                        <% } else { %>
                            N/A
                        <% } %>
                    </td>
                    
                    <td><%= new Date(appt.date).toLocaleString('en-US', { dateStyle: 'medium', timeStyle: 'short' }) %></td>
                    
                    <td><%= appt.status || 'Scheduled' %></td>
                </tr>
            <% }) %>
        </tbody>
    </table>
<% } else { %>
    <p>You have no upcoming appointments scheduled.</p>
<% } %>
</td>
    </div>
</body>
</html>