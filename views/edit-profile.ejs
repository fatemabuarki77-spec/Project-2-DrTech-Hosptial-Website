<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Edit Profile</title>
    <link rel="stylesheet" href="/css/doc-profile.css">
    <link
      rel="icon"
      href="/imgs/Gemini_Generated_Image_32rk1432rk1432rk_copy-removebg-preview.png"
      type="image/png"
    />
  </head>
  <body>
    <%- include('../partials/navbar') %>

    <div class="content-container">
      <div class="card form-card">
        <div class="card-header form-header">
          <h2>Edit Profile</h2>
          <p class="subtitle">Update your professional medical profile details.</p>
        </div>

        <form action="/profile/<%= myProfile._id %>?_method=PUT" method="POST" class="form-body">
          
          
          <div class="form-group">
            <label class="form-label">Doctor Name</label>
            <div class="user-display">
              <% if (myProfile && myProfile.name && typeof myProfile.name === 'object') { %>
                <%= myProfile.name.username || myProfile.name.name || 'Unnamed User' %>
              <% } else { %>
                <%= myProfile ? myProfile.name : 'N/A' %>
              <% } %>
            </div>
          </div>

        
          <div class="form-group">
            <label for="specialty" class="form-label">Specialty</label>
            <select name="specialty" id="specialty" class="form-control" required>
              <option value="-" <%= myProfile?.specialty === '-' ? 'selected' : '' %>>-- Select Specialty --</option>
              <option value="General Medicine" <%= myProfile?.specialty === 'General Medicine' ? 'selected' : '' %>>General Medicine</option>
              <option value="Cardiology" <%= myProfile?.specialty === 'Cardiology' ? 'selected' : '' %>>Cardiology</option>
              <option value="Pediatrics" <%= myProfile?.specialty === 'Pediatrics' ? 'selected' : '' %>>Pediatrics</option>
              <option value="Neurology" <%= myProfile?.specialty === 'Neurology' ? 'selected' : '' %>>Neurology</option>
              <option value="Psychiatry" <%= (myProfile?.specialty === 'Psychiatry' || myProfile?.specialty === 'Psychiatry') ? 'selected' : '' %>>Psychiatry</option>
            </select>
          </div>

         
          <div class="form-group">
            <label for="position" class="form-label">Position</label>
            <select id="position" name="position" class="form-control" required>
              <option value="" disabled <%= !myProfile?.position ? 'selected' : '' %>>-- Select Position --</option>
              <option value="junior" <%= myProfile?.position === 'junior' ? 'selected' : '' %>>Junior</option>
              <option value="Senior" <%= (myProfile?.position === 'Senior' || myProfile?.position === 'senior') ? 'selected' : '' %>>Senior</option>
              <option value="chief" <%= (myProfile?.position === 'chief' || myProfile?.position === 'cheif') ? 'selected' : '' %>>Chief</option>
              <option value="Consultant" <%= (myProfile?.position === 'Consultant' || myProfile?.position === 'consultant') ? 'selected' : '' %>>Consultant</option>
            </select>
          </div>

         
          <div class="form-group">
            <label for="experience" class="form-label">Experience</label>
            <input
              type="text"
              id="experience"
              name="experience"
              class="form-control"
              value="<%= myProfile?.experience || '' %>"
              placeholder="e.g., 5 years, 8+ Years"
              required
            />
          </div>

          <div class="form-group">
            <label class="form-label">Availability Status</label>
            <div class="radio-group">
              <label class="radio-label status-available-option">
                <input 
                  type="radio" 
                  name="Availability" 
                  value="true" 
                  <%= (myProfile?.Availability === true || myProfile?.Availability === 'true') ? 'checked' : '' %> 
                />
                <span class="custom-radio">Available</span>
              </label>
              <label class="radio-label status-unavailable-option">
                <input 
                  type="radio" 
                  name="Availability" 
                  value="false" 
                  <%= (myProfile?.Availability === false || myProfile?.Availability === 'false') ? 'checked' : '' %> 
                />
                <span class="custom-radio">Unavailable</span>
              </label>
            </div>
          </div>

          <div class="btn-group">
            <a href="/profile" class="btn btn-secondary">Cancel</a>
            <button type="submit" class="btn btn-primary">Save Changes</button>
          </div>
        </form>
      </div>
    </div>
  </body>
</html>