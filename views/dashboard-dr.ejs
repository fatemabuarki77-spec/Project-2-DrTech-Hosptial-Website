<!DOCTYPE html>

<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Doctor Dashboard - Dr.Tech Hospital</title>
        <link rel="stylesheet" href="/css/style.css" />
</head>

<body>

<%- include('../partials/navbar') %>

<header>
    <h1>Doctor Dashboard</h1>

```
<p>
    Welcome 
    <%= user.username || user.name %>
</p>
```

</header>

<hr>

<!-- Doctor Profile -->

<section>

<h2>My Profile</h2>

<% if (profile) { %>

<p>
    Name:
    <%= profile.name.username || profile.name.name %>
</p>

<p>
    Availability:
    <%= profile.Availability ? "Available" : "Unavailable" %>
</p>

<form action="/doctor/availability?_method=PUT" method="POST">

<select name="Availability">

<option value="true">
Available
</option>

<option value="false">
Unavailable
</option>

</select>

<button type="submit">
Update Status
</button>

</form>

<% } %>

</section>

<hr>

<!-- Upcoming Appointments -->

<section>

<h2>Upcoming Patient Visits</h2>

<% if (!bookings || bookings.length === 0) { %>

<p>
No appointments scheduled.
</p>

<% } else { %>

<ul>

<% bookings.forEach(app => { %>

<li>

<h3>

<a href="/doctor/patient/<%= app.patient._id %>">

<%= app.patient.name || app.patient.username %>

</a>

</h3>

<p>
Date:
<%= new Date(app.date).toLocaleString() %>
</p>

<p>
Service:
<%= app.service ? app.service.Name : "General Consultation" %>
</p>

<p>
Status:
<%= app.status %>
</p>

<a href="/doctor/patient/<%= app.patient._id %>">

Open Patient Chart

</a>

</li>

<br>

<% }) %>

</ul>

<% } %>

</section>

<hr>

<!-- Inpatients -->

<section>

<h2>Current Patients</h2>

<% if (!inpatients || inpatients.length === 0) { %>

<p>
No admitted patients.
</p>

<% } else { %>

<table border="1">

<thead>

<tr>

<th>
Patient
</th>

<th>
Gender
</th>

<th>
Ward
</th>

<th>
Illness
</th>

<th>
Action
</th>

</tr>

</thead>

<tbody>

<% inpatients.forEach(patient => { %>

<tr>

<td>

<a href="/doctor/patient/<%= patient._id %>">

<%= patient.name %>

</a>

</td>

<td>
<%= patient.gender %>
</td>

<td>
<%= patient.wards %>
</td>

<td>
<%= patient.illness %>
</td>

<td>

<a href="/doctor/patient/<%= patient._id %>">

View Chart

</a>

</td>

</tr>

<% }) %>

</tbody>

</table>

<% } %>

</section>

<hr>

<!-- Services -->

<section>

<h2>Medical Services</h2>

<a href="/service/new"> // ask for help ???????

Add New Service

</a>

</section>

</body>

</html>
