<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= profile?.name ? (profile.name.username || profile.name.name) : 'User' %>'s Profile</title>
    <link rel="stylesheet" href="/css/doc-profile.css">
    <link
      rel="icon"
      href="/imgs/Gemini_Generated_Image_32rk1432rk1432rk_copy-removebg-preview.png"
      type="image/png"
    />
</head>
<body>
    
  <%- include('../partials/navbar') %>

  <div class="content-container">
    <div class="card">
      
    
      <div class="card-header">
        <h2>
          <% if (profile && profile.name && typeof profile.name === 'object') { %>
            <%= profile.name.username || profile.name.name || 'Unnamed User' %>
          <% } else { %>
            <%= profile ? profile.name : 'N/A' %>
          <% } %>
        </h2>
        <% if (profile?.position) { %>
          <span class="badge-position"><%= profile.position %></span>
        <% } %>
      </div>

     
      <div class="card-body">
        <div class="info-group">
          <span class="label">Specialty</span>
          <span class="value"><%= profile?.specialty || 'N/A' %></span>
        </div>

        <div class="info-group">
          <span class="label">Experience</span>
          <span class="value"><%= profile?.experience || 'N/A' %></span>
        </div>

        <div class="info-group">
          <span class="label">Availability Status</span>
          <% if (profile?.Availability === true || profile?.Availability === 'true') { %>
            <span class="status-badge status-available">
              <span class="status-dot"></span> Available
            </span>
          <% } else { %>
            <span class="status-badge status-unavailable">
              <span class="status-dot"></span> Unavailable
            </span>
          <% } %>
        </div>
      </div>

 <div class="btn-group">
  <a href="/profile/<%= profile?._id %>/edit" class="btn btn-primary btn-block">
    Edit Profile
  </a>
</div>

    </div>
  </div>

</body>
</html>